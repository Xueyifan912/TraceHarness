# Model provider: anthropic or openai-compatible
MODEL_PROVIDER=anthropic

# Required for every provider
MODEL_ID=your-model-id

# Required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-api-key

# Optional custom Anthropic-compatible endpoint
# ANTHROPIC_BASE_URL=https://example.com/anthropic

# Optional fallback model used by the same provider
# FALLBACK_MODEL_ID=your-fallback-model-id

# Optional request timeout in seconds
REQUEST_TIMEOUT_SECONDS=60

# To use an OpenAI-compatible Chat Completions endpoint:
# 1. Change MODEL_PROVIDER above to openai-compatible.
# 2. Set both values below.
# OPENAI_COMPATIBLE_BASE_URL=https://example.com/v1
# OPENAI_COMPATIBLE_API_KEY=your-api-key
